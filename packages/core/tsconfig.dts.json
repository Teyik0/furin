{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "preserve", // at some point will target node for compat
    "moduleResolution": "bundler", // at some point will target node for compat
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
