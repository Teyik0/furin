    "@elysiajs/static": "^1.4.7"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "expect-type": "^1.3.0",
    "tailwindcss": "4"
  },
  "peerDependencies": {
    "elysia": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": ">= 5.0.0",
    "@types/bun": ">= 1.3.0"
  },
  "peerDependenciesMeta": {
    "@types/bun": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
