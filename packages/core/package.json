{
  "name": "elyra",
  "version": "0.1.0-alpha.2",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/elyra.js",
  "module": "./dist/elyra.js",
  "types": "./src/elyra.ts",
  "bin": {
    "elyra": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/elyra.ts",
      "bun": "./src/elyra.ts",
      "import": "./dist/elyra.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./build": {
      "types": "./src/build/index.ts",
      "bun": "./src/build/index.ts",
      "import": "./dist/build/index.js"
    },
    "./config": {
      "types": "./src/config.ts",
      "bun": "./src/config.ts",
      "import": "./dist/config.js"
    },
    "./router": {
      "types": "./src/router.ts",
      "bun": "./src/router.ts",
      "import": "./dist/router.js"
    },
    "./strip-plugin": {
      "types": "./src/plugin/index.ts",
      "bun": "./src/plugin/index.ts",
      "import": "./dist/plugin/index.js"
    },
    "./link": {
      "types": "./src/link.tsx",
      "bun": "./src/link.tsx",
      "import": "./dist/link.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:types": "tsc --noEmit",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.7",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.116.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "expect-type": "^1.3.0"
  },
  "peerDependencies": {
    "elysia": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": ">= 5.0.0",
    "@types/bun": ">= 1.3.0"
  }
}
