{
  "name": "@teyik0/furin",
  "version": "0.1.0-alpha.10",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/furin.js",
  "module": "./dist/furin.js",
  "types": "./src/furin.ts",
  "bin": {
    "furin": "./src/cli/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/furin.ts",
      "bun": "./src/furin.ts",
      "import": "./dist/furin.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./build": {
      "types": "./src/build/index.ts",
      "bun": "./src/build/index.ts",
      "import": "./dist/build/index.js"
    },
    "./config": {
      "types": "./src/config.ts",
      "bun": "./src/config.ts",
      "import": "./dist/config.js"
    },
    "./router": {
      "types": "./src/router.ts",
      "bun": "./src/router.ts",
      "import": "./dist/router.js"
    },
    "./strip-plugin": {
      "types": "./src/plugin/index.ts",
      "bun": "./src/plugin/index.ts",
      "import": "./dist/plugin/index.js"
    },
    "./link": {
      "types": "./src/link.tsx",
      "bun": "./src/link.tsx",
      "import": "./dist/link.js"
    },
    "./env": {
      "types": "./src/env.d.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:types": "tsc --noEmit",
    "build": "bun run build.ts",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.9",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.127.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "expect-type": "^1.3.0"
  },
  "peerDependencies": {
    "elysia": "catalog:",
    "evlog": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
