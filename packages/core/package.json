{
  "name": "@teyik0/elysion",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/elysion.js",
  "module": "./dist/elysion.js",
  "types": "./src/elysion.ts",
  "exports": {
    ".": {
      "types": "./src/elysion.ts",
      "bun": "./src/elysion.ts",
      "import": "./dist/elysion.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./build": {
      "types": "./src/build.ts",
      "bun": "./src/build.ts",
      "import": "./dist/build.js"
    },
    "./router": {
      "types": "./src/router.ts",
      "bun": "./src/router.ts",
      "import": "./dist/router.js"
    },
    "./strip-plugin": {
      "types": "./src/adapter/bun-plugin.ts",
      "bun": "./src/adapter/bun-plugin.ts",
      "import": "./dist/adapter/bun-plugin.js"
    },
    "./link": {
      "types": "./src/link.tsx",
      "bun": "./src/link.tsx",
      "import": "./dist/link.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:types": "tsc --noEmit",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/generator": "^7.29.1",
    "@babel/traverse": "^7.29.0",
