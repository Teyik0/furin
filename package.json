{
  "name": "@teyik0/root",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "fix": "ultracite fix",
    "test": "bun run --parallel --filter '*' test",
    "test:types": "bun run --parallel --filter '*' test:types",
    "build": "bun run --parallel --filter '*' build",
    "cache:clean": "rm -rf node_modules examples/*/node_modules packages/*/node_modules && bun pm cache rm",
    "iup": "bun update --interactive --recursive"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@biomejs/biome": "2.4.4",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/bun": "1.3.9",
    "lefthook": "^2.1.1",
    "typescript": "^5.9.3",
    "ultracite": "7.2.3"
  },
  "catalog": {
    "elysia": "^1.4.25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
