{
  "name": "@teyik0/furin/root",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "fix": "ultracite fix",
    "test": "bun run --parallel --filter '*' test",
    "test:types": "bun run --parallel --filter '*' test:types",
    "build": "bun run --parallel --filter '*' build",
    "cache:clean": "rm -rf node_modules examples/*/node_modules packages/*/node_modules && bun pm cache rm",
    "iup": "bun update --interactive --recursive"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "knip": "^6.2.0",
    "lefthook": "^2.1.4",
    "react-doctor": "^0.0.30",
    "typescript": "^6.0.2",
    "ultracite": "7.4.2"
  },
  "catalog": {
    "elysia": "^1.4.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
