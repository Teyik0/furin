{
  "name": "@elysion/root",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "ultracite": "7.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run --watch example/src/server.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "tsc": "tsc --noEmit",
    "cache:clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules && bun pm cache rm",
    "iup": "bun update --interactive --recursive"
  }
}
