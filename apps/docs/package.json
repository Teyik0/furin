{
  "name": "@teyik0/furin/docs",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "test": "bun test",
    "test:types": "tsc --noEmit",
    "start:debug": "bun run --cpu-prof --cpu-prof-md --heap-prof-md --inspect ./.furin/build/bun/server.js",
    "start": "./.furin/build/bun/server",
    "test:e2e": "bun run ./tests/hmr.ts",
    "generate:llms": "bun run scripts/generate-llms-txt.ts",
    "generate:content": "bun run scripts/generate-docs-content.ts",
    "build": "bun run generate:content && bun run generate:llms && furin build --target bun",
    "build:static": "bun run generate:content && bun run generate:llms && furin build --target static",
    "preview:static": "bun run scripts/preview-static.ts",
    "build:compiled": "bun run generate:content && bun run generate:llms && furin build --target bun --compile server",
    "build:embed": "bun run generate:content && bun run generate:llms && furin build --target bun --compile embed"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@orama/orama": "^3.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@teyik0/furin": "workspace:*",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "catalog:",
    "evlog": "catalog:",
    "hast-util-from-html": "^2.0.3",
    "hastscript": "^9.0.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit-parents": "^6.0.2"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
