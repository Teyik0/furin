{
  "name": "@teyik0/example-simple",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "test:types": "tsc --noEmit",
    "start": "NODE_ENV=production bun src/server.ts",
    "test:e2e": "bun run ./tests/hmr.ts",
    "build": "bun run ../../packages/core/src/cli/index.ts build --target bun",
    "build:compiled": "bun run ../../packages/core/src/cli/index.ts build --target bun --compile server",
    "build:embed": "bun run ../../packages/core/src/cli/index.ts build --target bun --compile embed",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@mdx-js/mdx": "^3.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@teyik0/furin": "workspace:*",
    "better-auth": "^1.5.5",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "catalog:",
    "hast": "^1.0.0",
    "hast-util-from-html": "^2.0.3",
    "hastscript": "^9.0.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
