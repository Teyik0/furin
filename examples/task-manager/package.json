    "elysia": "catalog:",
    "evlog": "^2.11.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.0",
    "@types/react": "catalog:",
